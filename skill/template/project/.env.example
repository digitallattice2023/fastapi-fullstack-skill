# 应用名（每个项目重新配置，最好与根目录名一致）
APP_NAME=myapp

# 应用基本配置（根据阶段配置）
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# PostgreSQL配置（异步）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db/myapp
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Redis配置
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=20
REDIS_POOL_TIMEOUT=10

# Celery配置
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY=4

# Cloudflare R2 config
SERVICE_NAME=s3
ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
REGION_NAME=auto
R2_BUCKET_NAME=myapp-storage

# 管理员账户配置
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT配置
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Resend邮件服务配置
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=${APP_NAME} <noreply@example.com>

# 验证码配置
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_LENGTH=6

# 缓存配置
USER_CACHE_EXPIRE_MINUTES=60
AUTH_CACHE_EXPIRE_MINUTES=30

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
