[project]
name = "{{ project_slug }}"
version = "{{ project_version }}"
description = "{{ project_description }}"
requires-python = ">=3.12"
dependencies = [
    # 基础依赖
    "fastapi>=0.100.0",
    "uvicorn[standard]>=0.23.0",
    "pydantic>=2.0.0",
    "pydantic[email]>=2.0.0",
    "pydantic-settings>=2.0.0",
    "sqlmodel>=0.0.16",
    "sqlalchemy>=2.0.0",
    "asyncpg>=0.29.0",
    "psycopg2-binary>=2.9.0",
    "alembic>=1.13.0",
    "loguru>=0.7.0",
    "python-ulid>=2.2.0",
    "python-multipart>=0.0.6",
{% if 'radar' in features %}
    "fastapi-radar>=0.2.0",
    "httpx>=0.27.0",
{% endif %}
{% if 'redis' in features or 'celery' in features %}
    # Redis
    "redis>=5.0.0",
{% endif %}
{% if 'celery' in features %}
    # Celery
    "celery>=5.3.0",
    "eventlet>=0.33.0",
{% endif %}
{% if 'storage' in features %}
    # R2/S3
    "boto3>=1.34.0",
{% endif %}
{% if 'email' in features %}
    # Email
    "resend>=0.6.0",
{% endif %}
{% if 'auth' in features or 'admin' in features %}
    # Admin
    "sqladmin>=0.16.0",
{% endif %}
{% if 'auth' in features %}
    # Auth
    "python-jose[cryptography]>=3.3.0",
    "bcrypt>=4.0.0",
    "itsdangerous>=2.1.0",
{% endif %}
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "httpx>=0.27.0",
    "black>=24.0.0",
    "isort>=5.13.0",
    "mypy>=1.8.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.black]
line-length = 88
target-version = ["py312"]

[tool.isort]
profile = "black"
line_length = 88

[tool.mypy]
python_version = "3.12"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false
ignore_missing_imports = true

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
