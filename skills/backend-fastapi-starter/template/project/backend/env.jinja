# 应用名
APP_NAME={{ project_name }}
SERVICE=FASTAPI

# 应用基本配置
APP_VERSION={{ project_version }}
DEBUG=true
ENVIRONMENT=development

# ============================================
# PostgreSQL 数据库（必选）
# ============================================
DATABASE_URL=postgresql+asyncpg://{{ db_user }}:{{ db_password }}@db/{{ db_name }}
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

{% if 'redis' in features or 'celery' in features %}
# ============================================
# Redis 缓存
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=20
REDIS_POOL_TIMEOUT=10
{% endif %}

{% if 'celery' in features %}
# ============================================
# Celery 任务队列
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY={{ celery_concurrency }}
{% endif %}

{% if 'storage' in features %}
# ============================================
# Cloudflare R2 对象存储
# ============================================
SERVICE_NAME=s3
ENDPOINT_URL={{ r2_endpoint_url }}
AWS_ACCESS_KEY_ID={{ r2_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ r2_secret_access_key }}
REGION_NAME=auto
R2_BUCKET_NAME={{ r2_bucket_name }}
{% endif %}

{% if 'auth' in features %}
# ============================================
# JWT 认证
# ============================================
SECRET_KEY={{ secret_key }}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_EMAIL={{ admin_email }}
ADMIN_PASSWORD={{ admin_password }}
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_LENGTH=6
USER_CACHE_EXPIRE_MINUTES=60
AUTH_CACHE_EXPIRE_MINUTES=30
{% endif %}

{% if 'email' in features %}
# ============================================
# Resend 邮件服务
# ============================================
RESEND_API_KEY={{ resend_api_key }}
RESEND_FROM_EMAIL={{ resend_from_email }}
{% endif %}

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=http://localhost:3000
