# 使用Python 3.12 slim镜像作为基础镜像
FROM python:3.12-slim

# 设置工作目录
WORKDIR /app

# 安装系统依赖
{% if use_china_mirrors %}
# 使用国内镜像源（阿里云）
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources \
    && sed -i 's/security.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources \
    && apt-get update && apt-get install -y \
        build-essential \
        libpq-dev \
        curl \
        && rm -rf /var/lib/apt/lists/*
{% else %}
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*
{% endif %}

# 安装uv包管理器
{% if use_china_mirrors %}
RUN pip install uv -i https://mirrors.aliyun.com/pypi/simple/
{% else %}
RUN pip install uv
{% endif %}

# 复制依赖文件
COPY pyproject.toml ./
# uv.lock 文件如果存在则复制（运行 uv lock 后生成）
COPY uv.lock ./
{% if use_china_mirrors %}
ENV UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
{% endif %}
# 使用 uv sync 安装依赖（需要 uv.lock）
RUN uv sync --frozen --no-dev --no-install-project

# 复制应用代码
COPY . .

# 创建非root用户以提高安全性
RUN useradd --create-home --shell /bin/bash app \
    && chown -R app:app /app

# 创建日志目录
RUN mkdir -p /app/logs && chown -R app:app /app/logs

# 切换到非root用户
USER app

# 暴露端口
EXPOSE 8000

# 设置环境变量
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
# 添加虚拟环境到PATH
ENV PATH="/app/.venv/bin:$PATH"
ENV VIRTUAL_ENV="/app/.venv"
# 传递构建时的 SERVICE 参数到运行时
ARG SERVICE
ENV SERVICE=${SERVICE}

# 启动脚本
CMD if [ "$SERVICE" = "FASTAPI" ]; then \
        echo "Starting FastAPI server..."; \
        uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${WORKERS:-1}; \
    elif [ "$SERVICE" = "CELERY" ]; then \
        echo "Starting Celery worker..."; \
        celery -A app.celery_app worker --loglevel=info --concurrency=${CELERY_CONCURRENCY:-4}; \
    else \
        echo "Error: SERVICE environment variable must be set to FASTAPI or CELERY"; \
        exit 1; \
    fi
