"""
Redis异步连接模块
提供Redis连接池管理和缓存装饰器
"""

import json
import hashlib
from datetime import datetime, timezone
from typing import Any, Optional, Callable, Dict
from functools import wraps
import redis.asyncio as redis
from redis.asyncio import ConnectionPool
from loguru import logger

from .config import settings


class RedisManager:
    """Redis管理器"""
    
    def __init__(self):
        self._pool: ConnectionPool | None = None
        self._client: redis.Redis | None = None
    
    def create_pool(self) -> ConnectionPool:
        """创建Redis连接池"""
        if self._pool is None:
            self._pool = ConnectionPool.from_url(
                settings.redis_url,
                max_connections=settings.redis_pool_size,
                socket_connect_timeout=settings.redis_pool_timeout,
                socket_keepalive=True,
                socket_keepalive_options={},
                health_check_interval=30,
                decode_responses=True,
            )
            logger.info(f"Redis连接池已创建: {settings.redis_url}")
        return self._pool
    
    def get_client(self) -> redis.Redis:
        """获取Redis客户端"""
        if self._client is None:
            pool = self.create_pool()
            self._client = redis.Redis(connection_pool=pool)
            logger.info("Redis客户端已创建")
        return self._client
    
    async def ping(self) -> bool:
        """检查Redis连接"""
        try:
            client = self.get_client()
            await client.ping()
            return True
        except Exception as e:
            logger.error(f"Redis连接失败: {e}")
            return False
    
    async def close(self):
        """关闭Redis连接"""
        if self._client:
            await self._client.aclose()
            logger.info("Redis客户端已关闭")
        if self._pool:
            await self._pool.aclose()
            logger.info("Redis连接池已关闭")


# 全局Redis管理器实例
redis_manager = RedisManager()


def get_redis() -> redis.Redis:
    """
    获取Redis客户端的便捷函数
    用作FastAPI路由的依赖注入
    """
    return redis_manager.get_client()


# 同步Redis连接（供Celery任务使用）
import redis as sync_redis


class SyncRedisManager:
    """同步Redis管理器（供Celery使用）"""
    
    def __init__(self):
        self._client: sync_redis.Redis | None = None
    
    def get_client(self) -> sync_redis.Redis:
        """获取同步Redis客户端"""
        if self._client is None:
            self._client = sync_redis.from_url(
                settings.redis_url,
                max_connections=settings.redis_pool_size,
                socket_connect_timeout=settings.redis_pool_timeout,
                socket_keepalive=True,
                decode_responses=True,
                health_check_interval=30,
            )
            logger.info(f"同步Redis客户端已创建: {settings.redis_url}")
        return self._client
    
    def ping(self) -> bool:
        """检查同步Redis连接"""
        try:
            client = self.get_client()
            client.ping()
            return True
        except Exception as e:
            logger.error(f"同步Redis连接失败: {e}")
            return False
    
    def close(self):
        """关闭同步Redis连接"""
        if self._client:
            self._client.close()
            logger.info("同步Redis客户端已关闭")


# 全局同步Redis管理器实例
sync_redis_manager = SyncRedisManager()


def get_sync_redis() -> sync_redis.Redis:
    """
    获取同步Redis客户端的便捷函数
    用于Celery任务中的Redis操作
    """
    return sync_redis_manager.get_client()


class CacheManager:
    """缓存管理器"""
    
    def __init__(self, redis_client: redis.Redis):
        self.redis = redis_client
    
    def _serialize_value(self, value: Any) -> str:
        """序列化值为JSON字符串"""
        def json_serializer(obj):
            if isinstance(obj, datetime):
                return obj.isoformat()
            raise TypeError(f"Object of type {type(obj)} is not JSON serializable")
        
        return json.dumps(value, default=json_serializer, ensure_ascii=False)
    
    def _deserialize_value(self, value: str) -> Any:
        """反序列化JSON字符串为值"""
        return json.loads(value)
    
    def _generate_cache_key(self, prefix: str, *args, **kwargs) -> str:
        """生成缓存键"""
        # 创建参数哈希
        params_str = f"{args}_{sorted(kwargs.items())}"
        params_hash = hashlib.md5(params_str.encode()).hexdigest()[:8]
        return f"{settings.app_name.lower()}:{prefix}:{params_hash}"
    
    async def get(self, key: str) -> Optional[Any]:
        """获取缓存值"""
        try:
            value = await self.redis.get(key)
            if value is None:
                return None
            return self._deserialize_value(value)
        except Exception as e:
            logger.error(f"缓存获取错误，键 {key}: {e}")
            return None
    
    async def set(
        self, 
        key: str, 
        value: Any, 
        expire: Optional[int] = None
    ) -> bool:
        """设置缓存值"""
        try:
            serialized_value = self._serialize_value(value)
            if expire:
                await self.redis.setex(key, expire, serialized_value)
            else:
                await self.redis.set(key, serialized_value)
            return True
        except Exception as e:
            logger.error(f"缓存设置错误，键 {key}: {e}")
            return False
    
    async def delete(self, key: str) -> bool:
        """删除缓存值"""
        try:
            result = await self.redis.delete(key)
            return result > 0
        except Exception as e:
            logger.error(f"缓存删除错误，键 {key}: {e}")
            return False
    
    async def exists(self, key: str) -> bool:
        """检查缓存键是否存在"""
        try:
            result = await self.redis.exists(key)
            return result > 0
        except Exception as e:
            logger.error(f"缓存检查错误，键 {key}: {e}")
            return False


def cache(
    prefix: str,
    expire: int = 3600,
    key_func: Optional[Callable] = None
):
    """
    缓存装饰器
    
    Args:
        prefix: 缓存键前缀
        expire: 过期时间（秒）
        key_func: 自定义键生成函数
    """
    
    def decorator(func: Callable):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            redis_client = get_redis()
            cache_manager = CacheManager(redis_client)
            
            # 生成缓存键
            if key_func:
                cache_key = key_func(*args, **kwargs)
            else:
                cache_key = cache_manager._generate_cache_key(prefix, *args, **kwargs)
            
            # 检查缓存
            if await cache_manager.exists(cache_key):
                cached_result = await cache_manager.get(cache_key)
                if cached_result is not None:
                    logger.debug(f"缓存命中，键: {cache_key}")
                    return cached_result
            
            # 执行函数并缓存结果
            result = await func(*args, **kwargs)
            await cache_manager.set(cache_key, result, expire)
            logger.debug(f"缓存已设置，键: {cache_key}")
            
            return result
        return wrapper
    return decorator