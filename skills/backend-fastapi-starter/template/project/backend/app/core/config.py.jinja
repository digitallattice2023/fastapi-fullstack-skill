"""
应用配置模块
按功能模块拆分 Config Mixin，仅启用的模块才会继承
"""

from typing import Optional, List
from pydantic import Field, field_validator
from pydantic_settings import BaseSettings, SettingsConfigDict


# ============================================================
# 核心配置（始终继承）
# ============================================================

class AppCore(BaseSettings):
    """应用基础配置"""
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=False,
        extra="ignore"
    )

    app_name: str = Field(default="{{ project_slug }}", description="应用名称")
    app_version: str = Field(default="{{ project_version }}", description="应用版本")
    debug: bool = Field(default=True, description="调试模式")
    environment: str = Field(default="development", description="运行环境")
    allowed_origins: str = Field(default="", description="允许的跨域源")

    @property
    def cors_origins(self) -> List[str]:
        """获取CORS允许的源列表"""
        if not self.allowed_origins:
            return ["*"] if self.debug else []
        return [origin.strip() for origin in self.allowed_origins.split(",")]

    @property
    def is_production(self) -> bool:
        return self.environment.lower() == "production"

    @property
    def is_development(self) -> bool:
        return self.environment.lower() == "development"


# ============================================================
# 数据库配置（始终继承）
# ============================================================

class DatabaseConfig(BaseSettings):
    """数据库配置"""
    database_url: str = Field(description="数据库连接URL")
    db_pool_size: int = Field(default=20, description="数据库连接池大小")
    db_max_overflow: int = Field(default=30, description="数据库连接池最大溢出")
    db_pool_timeout: int = Field(default=30, description="数据库连接超时")

    @field_validator("database_url")
    @classmethod
    def convert_database_url(cls, v: str) -> str:
        """转换数据库URL为异步格式"""
        if v.startswith("postgresql://"):
            return v.replace("postgresql://", "postgresql+asyncpg://", 1)
        return v


{% if 'redis' in features %}
# ============================================================
# Redis 配置
# ============================================================

class RedisConfig(BaseSettings):
    """Redis配置"""
    redis_url: Optional[str] = Field(default=None, description="Redis连接URL")
    redis_pool_size: int = Field(default=20, description="Redis连接池大小")
    redis_pool_timeout: int = Field(default=10, description="Redis连接超时")

    @field_validator("redis_url")
    @classmethod
    def convert_redis_url(cls, v: Optional[str]) -> Optional[str]:
        if v is None:
            return v
        if not v.startswith("redis://"):
            return f"redis://{v}"
        return v

{% endif %}
