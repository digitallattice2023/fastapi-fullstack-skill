import asyncio
from logging.config import fileConfig

from sqlalchemy import engine_from_config, pool
from sqlalchemy.ext.asyncio import async_engine_from_config
from alembic import context

# 导入SQLModel
from sqlmodel import SQLModel
import importlib
from pathlib import Path

# 通过 Feature Manifest 动态导入所有模型
# 约定：每个 feature 的 manifest.py 声明 models_module 字段
_features_dir = Path(__file__).parent.parent / "app" / "features"
for _feat in sorted(_features_dir.iterdir()):
    if _feat.is_dir() and not _feat.name.startswith("_"):
        manifest_file = _feat / "manifest.py"
        if manifest_file.exists():
            try:
                mod = importlib.import_module(f"app.features.{_feat.name}.manifest")
                manifest = getattr(mod, "manifest", None)
                if manifest and manifest.models_module:
                    importlib.import_module(manifest.models_module)
            except ImportError as e:
                print(f"警告: 无法导入 {_feat.name} 的模型: {e}")

# this is the Alembic Config object
config = context.config

if config.config_file_name is not None:
    fileConfig(config.config_file_name)

# 使用SQLModel的metadata
target_metadata = SQLModel.metadata

# 从环境变量获取数据库URL
import os
from app.core.config import settings

if not config.get_main_option("sqlalchemy.url"):
    config.set_main_option("sqlalchemy.url", settings.database_url)


def run_migrations_offline() -> None:
    """Run migrations in 'offline' mode."""
    url = config.get_main_option("sqlalchemy.url")
    context.configure(
        url=url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
    )

    with context.begin_transaction():
        context.run_migrations()


def run_migrations_online() -> None:
    """Run migrations in 'online' mode."""
    database_url = config.get_main_option("sqlalchemy.url")

    if database_url and "asyncpg" in database_url:
        def do_run_migrations(connection):
            context.configure(
                connection=connection,
                target_metadata=target_metadata,
                compare_type=True,
                compare_server_default=True
            )
            with context.begin_transaction():
                context.run_migrations()

        async def run_async_migrations():
            connectable = async_engine_from_config(
                config.get_section(config.config_ini_section, {}),
                prefix="sqlalchemy.",
                poolclass=pool.NullPool,
            )
            async with connectable.connect() as connection:
                await connection.run_sync(do_run_migrations)
            await connectable.dispose()

        asyncio.run(run_async_migrations())
    else:
        connectable = engine_from_config(
            config.get_section(config.config_ini_section, {}),
            prefix="sqlalchemy.",
            poolclass=pool.NullPool,
        )
        with connectable.connect() as connection:
            context.configure(
                connection=connection,
                target_metadata=target_metadata,
                compare_type=True,
                compare_server_default=True
            )
            with context.begin_transaction():
                context.run_migrations()


if context.is_offline_mode():
    run_migrations_offline()
else:
    run_migrations_online()
