<script setup lang="ts">
import { ref, onMounted } from 'vue'

/**
 * 初始化成功页面组件
 * 显示前后端技术栈信息，如果配置了后端则进行连通性检测
 */

// API 连接状态
const apiStatus = ref<boolean | null>({% if has_backend %}null{% else %}false{% endif %})

// 检测后端 API 连通性
async function checkApiHealth() {
{% if has_backend %}
  try {
    const response = await fetch('{{ backend_api_url }}/health', {
      method: 'GET',
      mode: 'cors',
    })
    apiStatus.value = response.ok
  } catch {
    apiStatus.value = false
  }
{% endif %}
}

// 页面加载时检测
onMounted(() => {
{% if has_backend %}
  checkApiHealth()
{% endif %}
})
</script>
